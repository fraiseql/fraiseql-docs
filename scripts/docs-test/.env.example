# Docs-test stack credentials and host port overrides.
#
# Copy this file to `.env` (which is gitignored) before running
# `docker compose -f scripts/docs-test/docker-compose.docs-test.yml ...`.
#
# The defaults baked into the Compose file match these values — `.env` is
# only required when overriding (e.g. on a host where 54320 is already in
# use, or to run the stack against alternative credentials).

# ---------------------------------------------------------------------------
# Database credentials. The same user / password / database name is used
# across PostgreSQL, MySQL, SQLite, and MSSQL so reproductions do not have
# to thread different credentials per backend.
#
# `fraiseql` matches the framework default in
# crates/fraiseql-server/src/server_config/defaults.rs:9
# (`postgresql://localhost/fraiseql`).
# ---------------------------------------------------------------------------
DB_USER=fraiseql
DB_PASSWORD=fraiseql_docs_test
DB_NAME=fraiseql

# MSSQL enforces a separate `sa` password policy (≥8 chars, mixed case,
# digit, symbol). Do NOT reuse DB_PASSWORD here — MSSQL will refuse to
# start if the policy is not met.
MSSQL_SA_PASSWORD=Fraiseql_docs_test1!

# ---------------------------------------------------------------------------
# Host port overrides. The Cycle 1 spec picked these to avoid collisions
# with the long-running developer postgres containers on this workstation
# (ports 33932–33966 are taken by other postgres:11-alpine instances).
# ---------------------------------------------------------------------------
HOST_PORT_POSTGRES=54320
HOST_PORT_MYSQL=13306
HOST_PORT_MSSQL=14330
HOST_PORT_REDIS=63790
HOST_PORT_NATS=42220
