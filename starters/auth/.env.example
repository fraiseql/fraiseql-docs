# .env.example — Environment variable template for the FraiseQL auth example
#
# Copy this file to .env and fill in values before running:
#   cp .env.example .env
#
# NEVER commit .env to source control. It is already listed in .gitignore.

# ----------------------------------------------------------------------------
# Database
#
# PostgreSQL connection string. The {user}:{password}@{host}:{port}/{db} form
# is standard. For local development with docker-compose, use the values from
# docker-compose.yml. For production, use a managed service (RDS, Cloud SQL,
# etc.) with SSL enforced.
# ----------------------------------------------------------------------------
DATABASE_URL=postgres://fraiseql:dev_password_change_in_prod@localhost:5432/fraiseql_auth

# ----------------------------------------------------------------------------
# OIDC Client Secret
#
# Secret issued by your OIDC provider (Google, Auth0, Keycloak, etc.) for the
# confidential client used by the FraiseQL server's PKCE callback handler.
# Set this to the value from your identity provider's application console.
# ----------------------------------------------------------------------------
OIDC_CLIENT_SECRET=replace-with-your-oidc-client-secret

# ----------------------------------------------------------------------------
# PKCE State Encryption Key
#
# 32 bytes of cryptographically random data encoded as a lowercase hex string
# (64 hex characters total). This key encrypts the OAuth state parameter that
# is stored between the /auth/start redirect and the /auth/callback exchange,
# preventing state token enumeration attacks.
#
# Generate a suitable value with:
#   openssl rand -hex 32
#
# IMPORTANT: Rotate this key if it is ever exposed. All in-flight OAuth
# sessions will be invalidated on rotation (users will need to re-login).
# ----------------------------------------------------------------------------
FRAISEQL_STATE_ENCRYPTION_KEY=replace-with-64-hex-chars-from-openssl-rand-hex-32

# ----------------------------------------------------------------------------
# JWT Secret (local development / HS256 only)
#
# Used by the Python FastAPI wrapper in src/auth.py to verify HS256-signed
# JWTs during local development and automated tests. This MUST NOT be used
# in production; production deployments should validate JWTs against the
# OIDC provider's JWKS endpoint (RS256 / ES256).
#
# Generate a suitable value with:
#   openssl rand -base64 32
# ----------------------------------------------------------------------------
JWT_SECRET=replace-with-a-strong-random-secret-for-local-dev-only

# ----------------------------------------------------------------------------
# Application environment
#
# Controls logging verbosity and whether stack traces are included in error
# responses. Set to "production" in deployed environments.
#
# Values: development | staging | production
# ----------------------------------------------------------------------------
APP_ENV=development
