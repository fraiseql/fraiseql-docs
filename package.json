{
  "name": "fraiseql-website",
  "type": "module",
  "version": "2.0.0",
  "description": "FraiseQL website - Schema. Compile. Serve.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "./scripts/build-diagrams.sh && astro build",
    "build:diagrams": "./scripts/build-diagrams.sh",
    "preview": "astro preview",
