    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.17.1",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "happy-dom": "^20.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
