---
// Schema Validator Component
import { getExampleSchemas } from '../../lib/validators/examples/schemas';

const examples = getExampleSchemas();
const dialectOptions = [
  { value: 'postgresql', label: 'PostgreSQL' },
  { value: 'mysql', label: 'MySQL' },
  { value: 'sqlite', label: 'SQLite' },
  { value: 'sqlserver', label: 'SQL Server' },
];
const formatOptions = [
  { value: 'json', label: 'JSON' },
  { value: 'yaml', label: 'YAML' },
];
---

<div class="schema-validator-container">
  <div class="validator-header">
    <h1>FraiseQL Schema Validator</h1>
    <p class="subtitle">
      Validate mutation return shapes and GraphQL Cascade patterns in your browser
    </p>
  </div>

  <div class="validator-main">
    <!-- Controls -->
    <div class="validator-controls">
      <div class="control-group">
        <label for="input-format">Format:</label>
        <select id="input-format" class="control-select">
          {formatOptions.map(opt => (
            <option value={opt.value}>{opt.label}</option>
          ))}
        </select>
      </div>

      <div class="control-group">
        <label for="sql-dialect">Database:</label>
        <select id="sql-dialect" class="control-select">
          {dialectOptions.map(opt => (
            <option value={opt.value}>{opt.label}</option>
          ))}
        </select>
      </div>

      <div class="control-group">
        <label for="example-select">Load Example:</label>
        <select id="example-select" class="control-select">
          <option value="">-- Choose an example --</option>
          {examples.map(ex => (
            <option value={ex.name}>{ex.name}</option>
          ))}
        </select>
      </div>

      <div class="control-group checkbox">
        <label for="enable-cascade">
          <input type="checkbox" id="enable-cascade" />
          <span>Validate Cascade</span>
        </label>
      </div>

      <button id="validate-btn" class="btn btn-primary">
        ▶ Validate Schema
      </button>

      <button id="clear-btn" class="btn btn-secondary">
        Clear
      </button>
    </div>

    <!-- Layout -->
    <div class="validator-layout">
      <!-- Editor Pane -->
      <div class="editor-pane">
        <div class="pane-header">
          <h2>Schema Input</h2>
          <span class="char-count">
            <span id="char-count">0</span> characters
          </span>
        </div>
        <textarea
          id="schema-input"
          class="schema-editor"
          placeholder="Paste your schema here or load an example..."
          spellcheck="false"
        ></textarea>
      </div>

      <!-- Results Pane -->
      <div class="results-pane">
        <div class="pane-header">
          <h2>Validation Results</h2>
          <div class="result-summary" id="result-summary">
            <span class="count count-errors" style="display:none">
              <span id="error-count">0</span> errors
            </span>
            <span class="count count-warnings" style="display:none">
              <span id="warning-count">0</span> warnings
            </span>
            <span class="count count-valid" style="display:none">
              <span id="valid-count">0</span> valid
            </span>
          </div>
        </div>
        <div class="results-list" id="results-list">
          <div class="results-empty">
            Validation results will appear here
          </div>
        </div>
      </div>
    </div>

    <!-- Export Section -->
    <div class="validator-footer">
      <button id="export-json-btn" class="btn btn-ghost">
        📄 Export JSON
      </button>
      <button id="export-markdown-btn" class="btn btn-ghost">
        📝 Export Markdown
      </button>
      <button id="share-btn" class="btn btn-ghost">
        🔗 Copy URL
      </button>
    </div>
  </div>
</div>

<script define:vars={{ examples }}>
  // Client-side validation logic
  import { validateSchemaSync } from '../../lib/validators/schema-validator';

  const schemaInput = document.getElementById('schema-input');
  const inputFormat = document.getElementById('input-format');
  const sqlDialect = document.getElementById('sql-dialect');
  const cascadeCheckbox = document.getElementById('enable-cascade');
  const validateBtn = document.getElementById('validate-btn');
  const clearBtn = document.getElementById('clear-btn');
  const exampleSelect = document.getElementById('example-select');
  const resultsList = document.getElementById('results-list');
  const resultSummary = document.getElementById('result-summary');
  const charCount = document.getElementById('char-count');

  // Character counter
  schemaInput.addEventListener('input', () => {
    charCount.textContent = schemaInput.value.length;
  });

  // Load example
  exampleSelect.addEventListener('change', () => {
    const exampleName = exampleSelect.value;
    if (!exampleName) return;

    const example = examples.find(e => e.name === exampleName);
    if (example) {
      const schemaJSON = JSON.stringify(example.schema, null, 2);
      schemaInput.value = schemaJSON;
      inputFormat.value = example.format || 'json';
      sqlDialect.value = example.dialect;
      charCount.textContent = schemaInput.value.length;
      exampleSelect.value = '';
    }
  });

  // Validate
  validateBtn.addEventListener('click', async () => {
    const input = schemaInput.value;
    if (!input.trim()) {
      alert('Please paste a schema or load an example');
      return;
    }

    try {
      const report = validateSchemaSync(input, {
        format: inputFormat.value,
        dialect: sqlDialect.value,
        validateCascade: cascadeCheckbox.checked,
        validateFunctionBodies: false,
        includeFunctionBodyAnalysis: false,
      });

      displayResults(report);
    } catch (error) {
      const message = error instanceof Error ? error.message : String(error);
      displayError(`Validation failed: ${message}`);
    }
  });

  // Clear
  clearBtn.addEventListener('click', () => {
    schemaInput.value = '';
    resultsList.innerHTML = '<div class="results-empty">Validation results will appear here</div>';
    resultSummary.innerHTML = '';
    charCount.textContent = '0';
  });

  // Display results
  function displayResults(report) {
    resultsList.innerHTML = '';
    const errors = report.errors.filter(e => e.severity === 'error');
    const warnings = report.errors.filter(e => e.severity === 'warning');

    // Update summary
    const summary = [];
    if (errors.length > 0) {
      summary.push(`<span class="count count-errors">${errors.length} errors</span>`);
    }
    if (warnings.length > 0) {
      summary.push(`<span class="count count-warnings">${warnings.length} warnings</span>`);
    }
    if (report.summary.validMutations > 0) {
      summary.push(`<span class="count count-valid">${report.summary.validMutations} valid</span>`);
    }
    resultSummary.innerHTML = summary.length > 0
      ? summary.join(' ')
      : '<span class="count count-valid">✓ No issues</span>';

    // Add errors
    if (errors.length > 0) {
      const errorSection = document.createElement('div');
      errorSection.className = 'result-section';
      errorSection.innerHTML = `<h3 class="section-title">❌ Errors (${errors.length})</h3>`;

      for (const error of errors) {
        const item = createResultItem(error);
        errorSection.appendChild(item);
      }
      resultsList.appendChild(errorSection);
    }

    // Add warnings
    if (warnings.length > 0) {
      const warningSection = document.createElement('div');
      warningSection.className = 'result-section';
      warningSection.innerHTML = `<h3 class="section-title">⚠️ Warnings (${warnings.length})</h3>`;

      for (const warning of warnings) {
        const item = createResultItem(warning);
        warningSection.appendChild(item);
      }
      resultsList.appendChild(warningSection);
    }

    // If no errors/warnings
    if (errors.length === 0 && warnings.length === 0) {
      resultsList.innerHTML = '<div class="results-success">✅ Schema is valid!</div>';
    }
  }

  function createResultItem(error) {
    const item = document.createElement('div');
    item.className = `result-item result-${error.severity}`;

    let html = `
      <div class="result-header">
        <span class="result-message">${escapeHtml(error.message)}</span>
    `;

    if (error.location) {
      html += `<span class="result-location">Line ${error.location.line}</span>`;
    }
    html += `</div>`;

    if (error.fix) {
      html += `<div class="result-fix"><strong>Fix:</strong> ${escapeHtml(error.fix)}</div>`;
    }

    if (error.path) {
      html += `<div class="result-path"><strong>Path:</strong> <code>${escapeHtml(error.path)}</code></div>`;
    }

    item.innerHTML = html;
    return item;
  }

  function displayError(message) {
    resultsList.innerHTML = `
      <div class="result-item result-error">
        <div class="result-header">
          <span class="result-message">${escapeHtml(message)}</span>
        </div>
      </div>
    `;
  }

  function escapeHtml(text) {
    const map = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    };
    return text.replace(/[&<>"']/g, m => map[m]);
  }
</script>

<style>
  .schema-validator-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  .validator-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .validator-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
  }

  .subtitle {
    font-size: 1rem;
    color: var(--gray-600);
    margin: 0;
  }

  .validator-controls {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    align-items: flex-end;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .control-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gray-700);
  }

  .control-select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--gray-300);
    border-radius: 0.375rem;
    font-size: 0.875rem;
    background: white;
  }

  .control-group.checkbox {
    flex-direction: row;
    align-items: center;
  }

  .control-group.checkbox label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
  }

  .control-group.checkbox input {
    margin: 0;
  }

  .btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-primary {
    background: #0066cc;
    color: white;
  }

  .btn-primary:hover {
    background: #0052a3;
  }

  .btn-secondary {
    background: #6b7280;
    color: white;
  }

  .btn-secondary:hover {
    background: #4b5563;
  }

  .btn-ghost {
    background: transparent;
    color: #0066cc;
    border: 1px solid #d1d5db;
  }

  .btn-ghost:hover {
    background: #f3f4f6;
  }

  .validator-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    min-height: 500px;
    margin-bottom: 1.5rem;
  }

  .editor-pane,
  .results-pane {
    border: 1px solid var(--gray-300);
    border-radius: 0.5rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: white;
  }

  .pane-header {
    padding: 1rem;
    border-bottom: 1px solid var(--gray-300);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .pane-header h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .char-count,
  .result-summary {
    font-size: 0.75rem;
    color: var(--gray-600);
  }

  .schema-editor {
    flex: 1;
    padding: 1rem;
    border: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.5;
    resize: none;
  }

  .results-list {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
  }

  .results-empty {
    color: var(--gray-500);
    text-align: center;
    padding: 2rem 1rem;
  }

  .results-success {
    padding: 1rem;
    background: #d1fae5;
    border-radius: 0.375rem;
    color: #065f46;
    text-align: center;
    font-weight: 600;
  }

  .result-section {
    margin-bottom: 1rem;
  }

  .section-title {
    margin: 0.5rem 0;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .result-item {
    padding: 0.75rem;
    margin-bottom: 0.5rem;
    border-radius: 0.375rem;
    border-left: 3px solid;
  }

  .result-error {
    background: #fee2e2;
    border-left-color: #dc2626;
  }

  .result-warning {
    background: #fef3c7;
    border-left-color: #f59e0b;
  }

  .result-header {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .result-message {
    flex: 1;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .result-location {
    font-size: 0.75rem;
    color: var(--gray-600);
  }

  .result-fix,
  .result-path {
    margin-top: 0.5rem;
    padding: 0.5rem;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
  }

  .count {
    font-size: 0.75rem;
    font-weight: 600;
    margin-right: 0.5rem;
  }

  .count-errors {
    color: #dc2626;
  }

  .count-warnings {
    color: #f59e0b;
  }

  .count-valid {
    color: #059669;
  }

  .validator-footer {
    display: flex;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--gray-300);
  }

  @media (max-width: 1024px) {
    .validator-layout {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .validator-controls {
      flex-direction: column;
      align-items: stretch;
    }

    .control-select {
      width: 100%;
    }
  }
</style>
