---
/**
 * Custom Hero Component for FraiseQL
 * Replaces Starlight default for A-tier visual impact
 */
const PAGE_TITLE_ID = '_top';
---

<div class="hero-container">
  <div class="hero-content">
    <!-- Main Tagline -->
    <h1 id={PAGE_TITLE_ID} class="hero-title">
      <span class="hero-word">Schema.</span>
      <span class="hero-word">Compile.</span>
      <span class="hero-word hero-accent">Serve.</span>
    </h1>

    <!-- Subhead -->
    <p class="hero-subhead">
      Define in your language. Configure in TOML. Compile to Rust. Serve at database speed.
    </p>

    <!-- CTA Buttons -->
    <div class="hero-actions">
      <a href="/getting-started/quickstart" class="hero-btn hero-btn-primary">
        Quick Start
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/concepts/how-it-works" class="hero-btn hero-btn-secondary">
        How It Works
      </a>
      <a href="https://github.com/fraiseql/fraiseql" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>

    <!-- Feature Pills -->
    <div class="hero-features">
      <span class="hero-pill">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        Sub-ms queries
      </span>
      <span class="hero-pill">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/>
          <path d="M12 12v9"/>
          <path d="m8 17 4 4 4-4"/>
        </svg>
        Any database
      </span>
      <span class="hero-pill">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m18 16 4-4-4-4"/>
          <path d="m6 8-4 4 4 4"/>
          <path d="m14.5 4-5 16"/>
        </svg>
        17 SDKs
      </span>
      <span class="hero-pill">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
          <path d="m9 12 2 2 4-4"/>
        </svg>
        Zero N+1
      </span>
    </div>
  </div>

  <!-- Visual: Compilation Flow -->
  <div class="hero-visual">
    <div class="compilation-flow">
      <!-- Step 1: Schema -->
      <div class="flow-step">
        <div class="flow-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <span class="flow-label">Schema</span>
        <code class="flow-code">schema.py</code>
      </div>

      <div class="flow-arrow">→</div>

      <!-- Step 2: Compile -->
      <div class="flow-step flow-step-active">
        <div class="flow-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 3v6"/>
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 15v6"/>
            <path d="M3 12h6"/>
            <path d="M15 12h6"/>
          </svg>
        </div>
        <span class="flow-label">Compile</span>
        <code class="flow-code">fraiseql build</code>
      </div>

      <div class="flow-arrow">→</div>

      <!-- Step 3: Serve -->
      <div class="flow-step">
        <div class="flow-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>
        <span class="flow-label">Serve</span>
        <code class="flow-code">GraphQL API</code>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    padding: var(--space-16) var(--space-4);
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr 1fr;
      padding: var(--space-24) var(--space-8);
      align-items: center;
    }
  }

  .hero-content {
    text-align: center;
  }

  @media (min-width: 1024px) {
    .hero-content {
      text-align: left;
    }
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 var(--space-6);
  }

  .hero-word {
    display: inline-block;
  }

  .hero-accent {
    color: var(--fraise-500);
  }

  .hero-subhead {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: var(--gray-600);
    line-height: 1.6;
    margin: 0 0 var(--space-8);
    max-width: 540px;
  }

  @media (min-width: 1024px) {
    .hero-subhead {
      margin-left: 0;
      margin-right: auto;
    }
  }

  :root[data-theme='dark'] .hero-subhead {
    color: var(--gray-400);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-bottom: var(--space-8);
  }

  @media (min-width: 1024px) {
    .hero-actions {
      justify-content: flex-start;
    }
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-lg);
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .hero-btn-primary {
    background: var(--fraise-500);
    color: white;
  }

  .hero-btn-primary:hover {
    background: var(--fraise-600);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .hero-btn-secondary {
    background: var(--gray-100);
    color: var(--gray-800);
  }

  :root[data-theme='dark'] .hero-btn-secondary {
    background: var(--gray-800);
    color: var(--gray-100);
  }

  .hero-btn-secondary:hover {
    background: var(--gray-200);
  }

  :root[data-theme='dark'] .hero-btn-secondary:hover {
    background: var(--gray-700);
  }

  .hero-btn-ghost {
    background: transparent;
    color: var(--gray-600);
    border: 1px solid var(--gray-300);
  }

  :root[data-theme='dark'] .hero-btn-ghost {
    color: var(--gray-400);
    border-color: var(--gray-700);
  }

  .hero-btn-ghost:hover {
    border-color: var(--fraise-500);
    color: var(--fraise-500);
  }

  .hero-features {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .hero-features {
      justify-content: flex-start;
    }
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--gray-100);
    border-radius: var(--radius-full);
    font-size: 0.875rem;
    color: var(--gray-600);
  }

  :root[data-theme='dark'] .hero-pill {
    background: var(--gray-800);
    color: var(--gray-400);
  }

  .hero-pill svg {
    color: var(--fraise-500);
  }

  /* Compilation Flow Visual */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .compilation-flow {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-8);
    background: var(--gray-50);
    border-radius: var(--radius-2xl);
    border: 1px solid var(--gray-200);
  }

  :root[data-theme='dark'] .compilation-flow {
    background: var(--gray-900);
    border-color: var(--gray-800);
  }

  .flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-xl);
    transition: all var(--transition-base);
  }

  .flow-step:hover {
    background: var(--gray-100);
  }

  :root[data-theme='dark'] .flow-step:hover {
    background: var(--gray-800);
  }

  .flow-step-active {
    background: var(--fraise-50);
  }

  :root[data-theme='dark'] .flow-step-active {
    background: var(--fraise-950);
  }

  .flow-step-active .flow-icon {
    color: var(--fraise-500);
  }

  .flow-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    color: var(--gray-600);
  }

  :root[data-theme='dark'] .flow-icon {
    background: var(--gray-800);
    color: var(--gray-400);
  }

  .flow-label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--gray-800);
  }

  :root[data-theme='dark'] .flow-label {
    color: var(--gray-200);
  }

  .flow-code {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--gray-500);
    background: var(--gray-200);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-md);
  }

  :root[data-theme='dark'] .flow-code {
    background: var(--gray-700);
    color: var(--gray-400);
  }

  .flow-arrow {
    font-size: 1.5rem;
    color: var(--gray-400);
    font-weight: 300;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .compilation-flow {
      flex-direction: column;
      gap: var(--space-2);
    }

    .flow-arrow {
      transform: rotate(90deg);
    }
  }
</style>
