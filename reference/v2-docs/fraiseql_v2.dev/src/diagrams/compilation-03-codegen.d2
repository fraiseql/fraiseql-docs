# Compilation Phase 3: Code Generation & Output

direction: right

rust_gen: "Rust Codegen" {
  shape: oval
  style.fill: "#9333ea"
  style.stroke: "#a855f7"
  style.font-color: "#ffffff"
  style.font-size: 20
}

migrations: "Migrations" {
  shape: page
  style.fill: "#ea580c"
  style.stroke: "#f97316"
  style.font-color: "#ffffff"
  style.font-size: 20
}

binary: "Compiled Binary" {
  shape: page
  style.fill: "#059669"
  style.stroke: "#10b981"
  style.font-color: "#ffffff"
  style.font-size: 20
}

rust_gen -> migrations: "Generate" {
  style.stroke-width: 3
  style.stroke: "#a855f7"
  style.font-size: 16
  style.bold: true
  style.font-color: "#581c87"
}

rust_gen -> binary: "Compile" {
  style.stroke-width: 3
  style.stroke: "#e03131"
  style.font-size: 16
  style.bold: true
  style.font-color: "#7a1616"
}
