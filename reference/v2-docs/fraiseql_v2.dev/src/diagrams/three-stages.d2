# Three Stages of FraiseQL

direction: right

define: "1. DEFINE\nSchema Definition" {
  style.font-size: 20
  style.bold: true
  style.fill: "#ea580c"
  style.stroke: "#f97316"
  style.font-color: "#ffffff"
  style.border-radius: 8
}

compile: "2. COMPILE\nCode Generation" {
  style.font-size: 20
  style.bold: true
  style.fill: "#9333ea"
  style.stroke: "#a855f7"
  style.font-color: "#ffffff"
  style.border-radius: 8
}

serve: "3. SERVE\nGraphQL API" {
  style.font-size: 20
  style.bold: true
  style.fill: "#059669"
  style.stroke: "#10b981"
  style.font-color: "#ffffff"
  style.border-radius: 8
}

define -> compile: "fraiseql build" {
  style.stroke-width: 3
  style.stroke: "#e03131"
  style.font-size: 16
  style.bold: true
  style.font-color: "#7a1616"
}

compile -> serve: "fraiseql serve" {
  style.stroke-width: 3
  style.stroke: "#e03131"
  style.font-size: 16
  style.bold: true
  style.font-color: "#7a1616"
}
