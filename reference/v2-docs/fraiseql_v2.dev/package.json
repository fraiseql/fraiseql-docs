{
  "name": "fraiseql-website",
  "type": "module",
  "version": "2.0.0",
  "description": "FraiseQL documentation website - Schema. Compile. Serve.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "./scripts/build-diagrams.sh && astro build",
    "build:diagrams": "./scripts/build-diagrams.sh",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run check && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.37.6",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.6.1",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "happy-dom": "^20.5.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
