---
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = [
  {
    name: "fraiseql",
    title: "Compiled GraphQL Engine",
    orbit: "inner",
    metric: "7-10×",
    description: "Core execution engine for GraphQL queries",
  },
  {
    name: "fraiseql-wire",
    title: "Streaming JSON Wire Protocol",
    orbit: "inner",
    metric: "200K×",
    description: "Memory-efficient streaming JSON transport",
  },
  {
    name: "confiture",
    title: "PostgreSQL Migrations",
    orbit: "inner",
    metric: "600×",
    description: "Fast, deterministic database migrations",
  },
  {
    name: "pg_tviews",
    title: "Incremental Materialized Views",
    orbit: "mid",
    metric: "2,083×",
    description: "Transactional materialized view refreshes",
  },
  {
    name: "jsonb_delta",
    title: "Efficient JSONB Operations",
    orbit: "mid",
    metric: "7×",
    description: "Optimized JSONB transformation and updates",
  },
  {
    name: "fraiseql-seed",
    title: "Auto-Resolving Test Data",
    orbit: "mid",
    metric: "300×",
    description: "Intelligent test data generation with relationships",
  },
  {
    name: "fraisier",
    title: "Deployment Orchestrator",
    orbit: "mid",
    metric: "Reference",
    description: "Canonical deployment and operations guide",
  },
  {
    name: "fraiseql-semis",
    title: "Semantic UUID Test Data",
    orbit: "outer",
    metric: "Alternative",
    description: "Semantic UUID generation for testing",
  },
  {
    name: "fraiseql-naming-police",
    title: "Naming Convention Enforcement",
    orbit: "outer",
    metric: "Quality",
    description: "Enforce consistent naming patterns",
  },
  {
    name: "velocitybench",
    title: "GraphQL Framework Benchmarking",
    orbit: "outer",
    metric: "28 Frameworks",
    description: "Comparative performance benchmarking suite",
  },
  {
    name: "fraiseql-ecosystem",
    title: "Meta-Analysis & Planning",
    orbit: "outer",
    metric: "Strategy",
    description: "Ecosystem analysis and strategic docs",
  },
];
---

<BaseLayout
  title="FraiseQL Ecosystem - 11 Interconnected Tools"
  description="Explore the complete FraiseQL galaxy: 11 tools designed to work together for database-first GraphQL execution."
>
  <div style="padding: 2rem; max-width: 1280px; margin: 0 auto;">
    <h1>FraiseQL Ecosystem</h1>
    <p>
      11 interconnected tools orbiting around PostgreSQL as your source of
      truth.
    </p>

    <div style="margin: 2rem 0;">
      <h2>Inner Orbit (Essential)</h2>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
        {
          projects
            .filter((p) => p.orbit === "inner")
            .map((p) => (
              <div
                style={{
                  border: "1px solid #e5e7eb",
                  padding: "1rem",
                  borderRadius: "0.5rem",
                }}
              >
                <h3>{p.metric}×</h3>
                <h4>{p.title}</h4>
                <p>{p.description}</p>
              </div>
            ))
        }
      </div>
    </div>

    <div style="margin: 2rem 0;">
      <h2>Mid Orbit (Enhancers)</h2>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
        {
          projects
            .filter((p) => p.orbit === "mid")
            .map((p) => (
              <div
                style={{
                  border: "1px solid #e5e7eb",
                  padding: "1rem",
                  borderRadius: "0.5rem",
                }}
              >
                <h3>{p.metric}</h3>
                <h4>{p.title}</h4>
                <p>{p.description}</p>
              </div>
            ))
        }
      </div>
    </div>

    <div style="margin: 2rem 0;">
      <h2>Outer Orbit (Supporting)</h2>
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;">
        {
          projects
            .filter((p) => p.orbit === "outer")
            .map((p) => (
              <div
                style={{
                  border: "1px solid #e5e7eb",
                  padding: "1rem",
                  borderRadius: "0.5rem",
                }}
              >
                <h3>{p.metric}</h3>
                <h4>{p.title}</h4>
                <p>{p.description}</p>
              </div>
            ))
        }
      </div>
    </div>

    <p style="margin-top: 2rem;">
      <a href="/">← Back to Home</a>
    </p>
  </div>
</BaseLayout>
