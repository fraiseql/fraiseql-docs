---
import BaseLayout from "../layouts/BaseLayout.astro";

const title =
  "FraiseQL - Database-First GraphQL Ecosystem | Stop Fighting Your Database";
const description =
  "FraiseQL is a compiled GraphQL execution engine with 11 interconnected tools. Database-first architecture, significant performance improvements, N+1 query prevention.";
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1 class="hero-title">Stop Fighting Your Database.</h1>
        <h2 class="hero-subtitle">Start Building Around It.</h2>
        <p class="hero-description">
          FraiseQL is a <strong>database-first GraphQL ecosystem</strong> with 11
          tools built around PostgreSQL as your source of truth. Compile-time
          optimization, deterministic execution, and built-in N+1 prevention.
        </p>
        <div class="hero-stats">
          <div class="stat">
            <div class="stat-value">7–10×</div>
            <div class="stat-label">Typical Performance</div>
          </div>
          <div class="stat">
            <div class="stat-value">11</div>
            <div class="stat-label">Interconnected Tools</div>
          </div>
          <div class="stat">
            <div class="stat-value">1–2ms</div>
            <div class="stat-label">Query Latency</div>
          </div>
        </div>
        <div class="hero-ctas">
          <a href="/how-it-works" class="btn btn-primary">Explore the Galaxy →</a>
          <a href="/ecosystem" class="btn btn-secondary">View Ecosystem</a>
        </div>
      </div>
      <div class="hero-visual">
        <!-- Placeholder for galaxy diagram -->
        <div class="galaxy-placeholder">
          <svg
            viewBox="0 0 400 400"
            xmlns="http://www.w3.org/2000/svg"
            class="galaxy-diagram"
          >
            <!-- Center database -->
            <circle cx="200" cy="200" r="20" fill="#e63946" opacity="0.8" />
            <text
              x="200"
              y="205"
              text-anchor="middle"
              dominant-baseline="middle"
              font-size="12"
              fill="white"
              font-weight="bold">DB</text
            >

            <!-- Inner orbit -->
            <circle
              cx="200"
              cy="200"
              r="80"
              fill="none"
              stroke="#e63946"
              stroke-width="1"
              stroke-dasharray="5,5"
              opacity="0.3"
            />
            <circle cx="260" cy="200" r="12" fill="#e63946" opacity="0.6" />
            <circle cx="180" cy="140" r="12" fill="#e63946" opacity="0.6" />
            <circle cx="180" cy="260" r="12" fill="#e63946" opacity="0.6" />

            <!-- Mid orbit -->
            <circle
              cx="200"
              cy="200"
              r="140"
              fill="none"
              stroke="#e63946"
              stroke-width="1"
              stroke-dasharray="5,5"
              opacity="0.3"
            />
            <circle cx="300" cy="200" r="10" fill="#e63946" opacity="0.5" />
            <circle cx="160" cy="90" r="10" fill="#e63946" opacity="0.5" />
            <circle cx="160" cy="310" r="10" fill="#e63946" opacity="0.5" />
            <circle cx="100" cy="200" r="10" fill="#e63946" opacity="0.5" />

            <!-- Outer orbit -->
            <circle
              cx="200"
              cy="200"
              r="180"
              fill="none"
              stroke="#e63946"
              stroke-width="1"
              stroke-dasharray="5,5"
              opacity="0.3"
            />
            <circle cx="360" cy="200" r="8" fill="#e63946" opacity="0.4" />
            <circle cx="150" cy="50" r="8" fill="#e63946" opacity="0.4" />
            <circle cx="150" cy="350" r="8" fill="#e63946" opacity="0.4" />
            <circle cx="40" cy="200" r="8" fill="#e63946" opacity="0.4" />
            <circle cx="250" cy="100" r="8" fill="#e63946" opacity="0.4" />
            <circle cx="250" cy="300" r="8" fill="#e63946" opacity="0.4" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Proof Points Section -->
  <section class="proof-points">
    <div class="container">
      <h2>Built for Scale and Consistency</h2>
      <div class="proof-grid">
        <div class="proof-card">
          <div class="proof-icon">🧪</div>
          <h3>2,400+ Tests</h3>
          <p>Comprehensive test coverage ensuring reliability and consistency.</p>
        </div>
        <div class="proof-card">
          <div class="proof-icon">📚</div>
          <h3>50+ Examples</h3>
          <p>Runnable examples for every major use case and pattern.</p>
        </div>
        <div class="proof-card">
          <div class="proof-icon">🌐</div>
          <h3>16 SDKs</h3>
          <p>Official SDKs for Python, TypeScript, Rust, Go, and more.</p>
        </div>
        <div class="proof-card">
          <div class="proof-icon">🗄️</div>
          <h3>4 Databases</h3>
          <p>
            PostgreSQL, MySQL, SQLite, and SQL Server support from one schema.
          </p>
        </div>
        <div class="proof-card">
          <div class="proof-icon">⚙️</div>
          <h3>11 Tools</h3>
          <p>Integrated ecosystem designed to work together seamlessly.</p>
        </div>
        <div class="proof-card">
          <div class="proof-icon">🎯</div>
          <h3>8.5/10 Cohesion</h3>
          <p>Ecosystem cohesion score measuring tool integration strength.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Personas Section -->
  <section class="personas">
    <div class="container">
      <h2>Explore by Role</h2>
      <div class="personas-grid">
        <a href="/for/developers" class="persona-card">
          <div class="persona-icon">💻</div>
          <h3>For Developers</h3>
          <p>Quick start guide, SDK documentation, schema authoring patterns</p>
        </a>
        <a href="/for/devops" class="persona-card">
          <div class="persona-icon">🚀</div>
          <h3>For DevOps</h3>
          <p>Deployment options, configuration, monitoring, production runbooks</p>
        </a>
        <a href="/for/architects" class="persona-card">
          <div class="persona-icon">🏗️</div>
          <h3>For Architects</h3>
          <p>Architecture principles, design decisions, integration patterns</p>
        </a>
        <a href="/for/compliance" class="persona-card">
          <div class="persona-icon">🔐</div>
          <h3>For Compliance</h3>
          <p>Audit capabilities, security features, compliance certifications</p>
        </a>
        <a href="/for/data-engineers" class="persona-card">
          <div class="persona-icon">📊</div>
          <h3>For Data Engineers</h3>
          <p>
            Apache Arrow Flight, analytics patterns, columnar delivery, Polars
            integration
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta">
    <div class="container">
      <h2>Ready to build database-first?</h2>
      <p>Start with the ecosystem overview or dive into the documentation.</p>
      <div class="cta-buttons">
        <a href="/ecosystem" class="btn btn-primary">Explore Ecosystem</a>
        <a href="/docs" class="btn btn-secondary">Read Docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: var(--gradient-hero);
    color: white;
    padding: var(--spacing-20) var(--spacing-6);
  }

  .hero-content {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-16);
    align-items: center;
  }

  .hero-title {
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    margin: 0 0 var(--spacing-2) 0;
  }

  .hero-subtitle {
    font-size: var(--text-3xl);
    font-weight: 600;
    line-height: var(--leading-tight);
    margin: 0 0 var(--spacing-6) 0;
    opacity: 0.9;
  }

  .hero-description {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--spacing-8);
    opacity: 0.95;
  }

  .hero-stats {
    display: flex;
    gap: var(--spacing-12);
    margin-bottom: var(--spacing-8);
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-value {
    font-size: var(--text-2xl);
    font-weight: 700;
  }

  .stat-label {
    font-size: var(--text-sm);
    opacity: 0.9;
  }

  .hero-ctas {
    display: flex;
    gap: var(--spacing-4);
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .galaxy-placeholder {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .galaxy-diagram {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 10px 30px rgba(230, 57, 70, 0.3));
  }

  /* Proof Points */
  .proof-points {
    padding: var(--spacing-20) var(--spacing-6);
    background: var(--color-surface);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-6);
    margin-top: var(--spacing-12);
  }

  .proof-card {
    background: white;
    padding: var(--spacing-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    text-align: center;
    transition: all var(--transition-base);
  }

  .proof-card:hover {
    border-color: var(--color-strawberry-500);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .proof-icon {
    font-size: var(--text-4xl);
    margin-bottom: var(--spacing-4);
  }

  .proof-card h3 {
    margin-top: 0;
    color: var(--color-strawberry-500);
  }

  .proof-card p {
    color: var(--color-text-muted);
    margin: 0;
    font-size: var(--text-sm);
  }

  /* Personas */
  .personas {
    padding: var(--spacing-20) var(--spacing-6);
  }

  .personas-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--spacing-6);
    margin-top: var(--spacing-12);
  }

  .persona-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-6);
    text-decoration: none;
    text-align: center;
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .persona-card:hover {
    border-color: var(--color-strawberry-500);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    background: var(--color-surface);
  }

  .persona-icon {
    font-size: var(--text-4xl);
    margin-bottom: var(--spacing-4);
  }

  .persona-card h3 {
    margin: 0 0 var(--spacing-3) 0;
    color: var(--color-text);
  }

  .persona-card p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  /* CTA Section */
  .cta {
    background: var(--color-strawberry-50);
    padding: var(--spacing-16) var(--spacing-6);
    text-align: center;
  }

  .cta h2 {
    color: var(--color-strawberry-700);
    margin-top: 0;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-4);
    justify-content: center;
    margin-top: var(--spacing-8);
  }

  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: var(--spacing-12);
    }

    .proof-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .personas-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--spacing-12) var(--spacing-4);
    }

    .hero-title {
      font-size: var(--text-3xl);
    }

    .hero-subtitle {
      font-size: var(--text-2xl);
    }

    .hero-ctas {
      flex-direction: column;
    }

    .proof-grid {
      grid-template-columns: 1fr;
    }

    .personas-grid {
      grid-template-columns: 1fr;
    }

    .cta-buttons {
      flex-direction: column;
    }
  }
</style>
