metrics_enabled = false
admin_api_enabled = true
admin_token = "red-evidence-admin-token-do-not-ship"
introspection_enabled = false
pool_min_size = 5
pool_max_size = 20
pool_timeout_secs = 30
EOF

$ docker run --rm \
    --name fraiseql-red-tenancy \
    --network fraiseql-docs-test_default \
