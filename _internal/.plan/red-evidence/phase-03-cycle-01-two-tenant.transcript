# admin endpoint.

$ curl -s -o /dev/null -w 'HTTP %{http_code}\n' \
       -X GET http://localhost:8080/api/v1/admin/tenants
HTTP 404

$ curl -s -o /dev/null -w 'HTTP %{http_code}\n' \
       -X PUT http://localhost:8080/api/v1/admin/tenants/foo \
       -H 'Content-Type: application/json' \
       -d '{"schema":{},"connection":{}}'
HTTP 404

# Same 404 for `bar`. The handler is not mounted at all because
# `admin_api_enabled = false` short-circuits `mount_admin_api()`
# (server/routing/admin.rs:L389-L489).

