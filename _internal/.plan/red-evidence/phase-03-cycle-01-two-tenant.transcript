# Step 2 — sidecar binary with admin_api_enabled = true + admin_token set.

$ cat > /tmp/tenancy-red-overlay.toml << 'EOF'
bind_addr = "0.0.0.0:8080"
database_url = "postgresql://fraiseql:fraiseql_docs_test@postgres:5432/fraiseql"
