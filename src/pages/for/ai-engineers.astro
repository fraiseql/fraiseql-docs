    background: #f7fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    padding: 0.75rem;
    font-size: 0.8rem;
    margin: 0.5rem 0 0 0;
  }

  .workflow-step code {
    font-family: 'Courier New', monospace;
    color: #2d3748;
    line-height: 1.4;
  }

  .cost {
    font-size: 0.875rem;
    color: #667eea;
    font-weight: 600;
    margin-top: 0.5rem;
  }

  /* Comparison table wrapper */
  .comparison-table-wrapper {
    overflow-x: auto;
    margin-bottom: 2rem;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
  }

  .comparison-table thead {
    background: #f7fafc;
  }

  .comparison-table th {
    padding: 1rem;
    text-align: left;
    font-weight: 700;
    color: #1a202c;
    border-bottom: 2px solid #e2e8f0;
  }

