    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .use-case-card h3 {
    margin-top: 0;
    color: #667eea;
  }

  /* Integration cards */
  .integration-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .integration-card h3 {
    margin-top: 0;
  }

  .integration-card pre {
    background: #f7fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.8rem;
