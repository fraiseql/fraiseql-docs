    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 2rem;
    margin-bottom: 1.5rem;
  }

  .optimization-card pre {
    background: #f7fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.8rem;
    margin: 1rem 0 0 0;
  }

  .optimization-card code {
    font-family: 'Courier New', monospace;
    color: #2d3748;
    line-height: 1.4;
  }

  .impact {
    background: #edf2f7;
    padding: 1rem;
