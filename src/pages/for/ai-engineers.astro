    .audience-hero h1 {
      font-size: 2rem;
    }

    .comparison-box {
      grid-template-columns: 1fr;
    }

    .workflow-step {
      flex-direction: column;
      align-items: center;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      text-align: center;
    }

    .comparison-table {
      font-size: 0.9rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 0.75rem;
    }
  }
</style>
