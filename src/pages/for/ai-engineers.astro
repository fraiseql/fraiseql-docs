    line-height: 1.3;
  }

  /* Token analysis table */
  .analysis-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .analysis-table thead {
    background: #f7fafc;
  }

  .analysis-table th {
    padding: 1rem;
    text-align: left;
