    font-size: 0.95rem;
  }

  .tool-category ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tool-category li {
    padding: 0.25rem 0;
    color: #4a5568;
    font-size: 0.875rem;
  }

  /* CTA */
  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 1rem 2rem;
