  .btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
  }

  .btn-secondary {
    background: white;
    color: #667eea;
    border: 2px solid #667eea;
  }

  .btn-secondary:hover {
    background: #f7fafc;
  }

  @media (max-width: 768px) {
    .audience-hero h1 {
      font-size: 2rem;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      text-align: center;
    }

    .monitoring-table,
    .failure-table {
      font-size: 0.9rem;
    }

    .monitoring-table th,
    .failure-table th,
    .monitoring-table td,
    .failure-table td {
      padding: 0.75rem;
    }
  }
</style>
