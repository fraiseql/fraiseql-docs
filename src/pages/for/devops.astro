    font-weight: 700;
    color: #1a202c;
    border-bottom: 2px solid #e2e8f0;
  }

  .monitoring-table td,
  .failure-table td {
    padding: 1rem;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
  }

  .monitoring-table tbody tr:last-child td,
  .failure-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* Debug steps */
  .debug-steps {
    color: #4a5568;
    line-height: 2;
    padding-left: 2rem;
  }

  .debug-steps li {
    margin-bottom: 0.5rem;
  }

  /* Checklist */
  .checklist {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 2rem;
    margin-bottom: 2rem;
  }

