    font-size: 2rem;
    margin-bottom: var(--spacing-8);
    color: var(--color-text);
  }

  .use-case-content h3 {
    font-size: 1.25rem;
    margin: var(--spacing-6) 0 var(--spacing-3) 0;
    color: var(--color-text);
  }

