  @media (max-width: 768px) {
    .use-case-hero h1 {
      font-size: 2rem;
    }

    .use-case-content h2 {
      font-size: 1.5rem;
    }

    .before-after {
      flex-direction: column;
      gap: var(--spacing-2);
    }

    .arrow {
      transform: rotate(90deg);
    }

    .cta-buttons {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
