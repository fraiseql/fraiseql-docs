    text-align: center;
  }

  .value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--fraise-500);
    margin-bottom: var(--spacing-1);
  }

  .label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .arrow {
    color: var(--color-text-muted);
    font-size: 1.5rem;
  }

  /* Best Practices */
