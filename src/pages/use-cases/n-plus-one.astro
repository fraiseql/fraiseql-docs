  }

  .use-case-hero h1 {
    font-size: 2.5rem;
    margin: 0 0 var(--spacing-3) 0;
    font-weight: 700;
  }

  .use-case-hero p {
    font-size: 1.125rem;
    opacity: 0.95;
    margin: 0;
  }

  .container {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 var(--spacing-6);
  }

  .use-case-content {
    padding: var(--spacing-16) var(--spacing-6);
  }

  .use-case-content section {
    margin-bottom: var(--spacing-16);
  }

