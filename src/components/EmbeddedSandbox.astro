---
/**
 * EmbeddedSandbox Component
 *
 * Embeds Apollo Sandbox (same GraphQL IDE as `fraiseql serve`) into documentation.
 * Allows readers to try features directly in the browser.
 *
 * @example
 * ```astro
 * <EmbeddedSandbox
 *   endpoint="https://demo.fraiseql.dev/graphql"
 *   title="Automatic Where Example"
 *   description="Filter users by active status and email"
 *   height="700px"
 *   preloadedQuery={`query {
 *     users(where: { is_active: { _eq: true } }) {
 *       id name email
 *     }
 *   }`}
 * />
 * ```
 *
 * Features:
 * - Embeds Apollo Sandbox from CDN
 * - Configurable endpoint
 * - Pre-loaded example queries
 * - Privacy notice with link to security guide
 * - Responsive design
 * - Dark/light theme support
 * - No external data collection by default
 */

interface Props {
  /** GraphQL endpoint URL (absolute or relative) */
  endpoint: string;
  /** Optional title above the sandbox */
  title?: string;
  /** Optional description of what to try */
  description?: string;
  /** Sandbox height (default: "600px") */
  height?: string;
  /** GraphQL query to pre-load in the sandbox */
  preloadedQuery?: string;
  /** Optional custom placeholder query hint */
  queryHint?: string;
}

const {
  endpoint,
  title,
  description,
  height = "600px",
  preloadedQuery = "",
  queryHint = "Try modifying the query or create your own..."
} = Astro.props;

// Generate unique ID for this sandbox instance
const sandboxId = `sandbox-${Math.random().toString(36).substr(2, 9)}`;

// Escape GraphQL query for safe embedding in script
const escapedQuery = preloadedQuery ? JSON.stringify(preloadedQuery) : '""';
---

<div class="embedded-sandbox-wrapper">
  {title && <h3 class="sandbox-title">{title}</h3>}
  {description && <p class="sandbox-description">{description}</p>}

  <!-- Apollo Sandbox Container -->
  <div class="sandbox-container">
    <div id={sandboxId} class="sandbox-player">
      <div class="sandbox-loading">
        <div class="spinner"></div>
        <p>Loading Apollo Sandbox...</p>
      </div>
    </div>
  </div>

  <!-- Privacy Notice -->
  <div class="sandbox-privacy-notice">
    <svg
      class="notice-icon"
      width="16"
      height="16"
      viewBox="0 0 16 16"
      fill="currentColor"
    >
      <path
        d="M8 1C4.1 1 1 4.1 1 8s3.1 7 7 7 7-3.1 7-7-3.1-7-7-7zm0 12.5c-3 0-5.5-2.5-5.5-5.5S5 2.5 8 2.5s5.5 2.5 5.5 5.5-2.5 5.5-5.5 5.5z"
      ></path>
      <path d="M7 4h2v5H7z"></path>
      <path d="M7 10h2v2H7z"></path>
    </svg>
    <span class="notice-text">
      This sandbox uses <strong>Apollo Sandbox</strong> (the same GraphQL IDE as
      <code>fraiseql serve</code>). Your queries execute against the endpoint below.
      No data is sent to Apollo. <a href="/guides/apollo-sandbox-security"
        >Learn more about privacy →</a
      >
    </span>
  </div>
</div>

<!-- Apollo Sandbox Initialization Script -->
<script define:vars={{ sandboxId, endpoint, escapedQuery, queryHint }}>
  // Wait for Apollo Sandbox CDN to load
  function loadApolloSandbox() {
    // Check if Apollo Sandbox is already loaded
    if (window.EmbeddedSandbox) {
      initSandbox();
      return;
    }

    // Load Apollo Sandbox from CDN
    const script = document.createElement("script");
    script.src =
      "https://embeddable-sandbox.cdn.apollographql.com/_latest/embeddable-sandbox.umd.production.min.js";
    script.async = true;
    script.onload = initSandbox;
    script.onerror = () => {
      const container = document.getElementById(sandboxId);
      if (container) {
        container.innerHTML =
          '<div class="sandbox-error"><p>Failed to load Apollo Sandbox. Please check your connection.</p></div>';
      }
    };
    document.head.appendChild(script);
  }

  // Initialize Apollo Sandbox with configuration
  function initSandbox() {
    try {
      const initialState = escapedQuery
        ? {
            document: escapedQuery,
          }
        : undefined;

      new window.EmbeddedSandbox({
        target: `#${sandboxId}`,
        initialEndpoint: endpoint,
        initialState: initialState,
        includeCookies: false,
        document: escapedQuery || undefined,
        persist: false, // Don't persist to localStorage
      });
    } catch (error) {
      console.error("Failed to initialize Apollo Sandbox:", error);
      const container = document.getElementById(sandboxId);
      if (container) {
        container.innerHTML =
          '<div class="sandbox-error"><p>Failed to initialize Apollo Sandbox.</p></div>';
      }
    }
  }

  // Load when DOM is ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadApolloSandbox);
  } else {
    loadApolloSandbox();
  }
</script>

<style>
  .embedded-sandbox-wrapper {
    margin: 2rem 0;
    border-radius: 8px;
    overflow: hidden;
    background: var(--sl-color-bg);
  }

  .sandbox-title {
    margin: 0;
    padding: 1rem;
    background: var(--sl-color-gray-1);
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-size: 1.1rem;
    font-weight: 600;
  }

  .sandbox-description {
    margin: 0;
    padding: 0.75rem 1rem;
    background: var(--sl-color-gray-2);
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-size: 0.9rem;
    color: var(--sl-color-gray-3);
  }

  .sandbox-container {
    border: 1px solid var(--sl-color-gray-5);
    border-top: none;
    border-radius: 0 0 8px 8px;
    overflow: hidden;
  }

  .sandbox-player {
    width: 100%;
    height: v-bind(height);
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--sl-color-bg);
  }

  .sandbox-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--sl-color-gray-5);
    border-top-color: var(--sl-color-accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .sandbox-loading p {
    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
  }

  .sandbox-error {
    padding: 2rem;
    text-align: center;
    color: var(--sl-color-gray-2);
    background: var(--sl-color-red);
    border-radius: 4px;
  }

  .sandbox-error p {
    margin: 0;
  }

  /* Privacy Notice */
  .sandbox-privacy-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--sl-color-gray-6);
    border-top: 1px solid var(--sl-color-gray-5);
    border-radius: 0 0 8px 8px;
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
  }

  .notice-icon {
    flex-shrink: 0;
    margin-top: 0.125rem;
    color: var(--sl-color-gray-3);
  }

  .notice-text {
    line-height: 1.4;
  }

  .notice-text strong {
    font-weight: 600;
    color: var(--sl-color-text);
  }

  .notice-text code {
    background: var(--sl-color-gray-5);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    font-family: var(--sl-font-mono);
    font-size: 0.85em;
    color: var(--sl-color-text);
  }

  .notice-text a {
    color: var(--sl-color-accent);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid currentColor;
  }

  .notice-text a:hover {
    text-decoration: underline;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .embedded-sandbox-wrapper {
      margin: 1.5rem 0;
    }

    .sandbox-player {
      height: 500px;
      min-height: 300px;
    }

    .sandbox-title {
      font-size: 1rem;
      padding: 0.875rem;
    }

    .sandbox-description {
      padding: 0.625rem 0.875rem;
      font-size: 0.85rem;
    }

    .sandbox-privacy-notice {
      font-size: 0.8rem;
      padding: 0.75rem 0.875rem;
      gap: 0.5rem;
    }
  }

  /* Dark Mode Adjustments */
  :global(.dark) .sandbox-player {
    background: var(--sl-color-gray-6);
  }

  :global(.dark) .sandbox-container {
    border-color: var(--sl-color-gray-4);
  }

  :global(.dark) .sandbox-title {
    background: var(--sl-color-gray-5);
    border-bottom-color: var(--sl-color-gray-4);
  }

  :global(.dark) .sandbox-description {
    background: var(--sl-color-gray-4);
    border-bottom-color: var(--sl-color-gray-3);
  }

  :global(.dark) .sandbox-privacy-notice {
    background: var(--sl-color-gray-5);
    border-top-color: var(--sl-color-gray-4);
    color: var(--sl-color-gray-1);
  }

  :global(.dark) .notice-text code {
    background: var(--sl-color-gray-3);
    color: var(--sl-color-gray-6);
  }
</style>
