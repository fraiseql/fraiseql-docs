# Observer Flow: Trigger to Execution

direction: down

mutation: "Data Write" {
  shape: oval
  style.fill: "#e11d48"
  style.stroke: "#f43f5e"
  style.font-color: "#ffffff"
  style.font-size: 20
}

evaluator: "Condition Evaluator" {
  shape: oval
  style.fill: "#9333ea"
  style.stroke: "#a855f7"
  style.font-color: "#ffffff"
  style.font-size: 20
}

queue: "Message Queue" {
  shape: cylinder
  style.fill: "#ea580c"
  style.stroke: "#f97316"
  style.font-color: "#ffffff"
  style.font-size: 20
}

actions: "Execute Actions" {
  shape: oval
  style.fill: "#059669"
  style.stroke: "#10b981"
  style.font-color: "#ffffff"
  style.font-size: 20
}

mutation -> evaluator: "Triggers" {
  style.stroke-width: 3
  style.stroke: "#e03131"
  style.font-size: 16
  style.bold: true
  style.font-color: "#7a1616"
}

evaluator -> queue: "If matched" {
  style.stroke-width: 3
  style.stroke: "#a855f7"
  style.font-size: 16
  style.bold: true
  style.font-color: "#581c87"
}

queue -> actions: "Execute" {
  style.stroke-width: 3
  style.stroke: "#e03131"
  style.font-size: 16
  style.bold: true
  style.font-color: "#7a1616"
}
